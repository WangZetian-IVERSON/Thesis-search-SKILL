<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <title>论文阅读工作台</title>
  <style>
    :root {
      --bg: #f7f7f1;
      --panel: #ffffff;
      --ink: #1f2933;
      --muted: #60717f;
      --line: #d9e2ec;
      --nav: #263f58;
      --accent: #0b7f77;
      --accent-2: #d99a24;
      --soft: #eef8f5;
    }
    * { box-sizing: border-box; }
    body { margin: 0; font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: radial-gradient(circle at 86% 8%, #d8f3e8, transparent 28%), var(--bg); color: var(--ink); }
    header { padding: 22px 30px; background: rgba(255,255,255,.78); border-bottom: 1px solid var(--line); backdrop-filter: blur(10px); }
    .title-row { display: flex; align-items: center; gap: 12px; }
    .dot { width: 16px; height: 16px; border-radius: 50%; background: #3dbb75; box-shadow: 0 0 0 5px #dff4e8; }
    h1 { margin: 0; font-size: 26px; }
    header p { margin: 6px 0 0 28px; color: var(--muted); }
    main { max-width: 1260px; margin: 0 auto; padding: 24px 30px 40px; }
    .toolbar { background: rgba(255,255,255,.9); border: 1px solid var(--line); border-radius: 8px; padding: 16px; box-shadow: 0 12px 28px rgba(31,41,51,.08); }
    .filters { display: grid; grid-template-columns: 170px 170px 170px 1fr 150px; gap: 12px; align-items: end; }
    label { display: grid; gap: 6px; color: var(--muted); font-size: 13px; font-weight: 700; }
    input, select, button { font: inherit; border: 1px solid var(--line); border-radius: 6px; padding: 10px 12px; background: #fff; color: var(--ink); }
    button { cursor: pointer; font-weight: 700; }
    .primary { background: #35c48a; border-color: #25a978; color: #102a43; }
    .stats { margin: 18px 0 14px; color: var(--muted); display: flex; gap: 16px; flex-wrap: wrap; }
    .grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; }
    .paper-card { background: rgba(255,255,255,.94); border: 1px solid var(--line); border-radius: 8px; padding: 16px; min-height: 360px; display: flex; flex-direction: column; gap: 10px; box-shadow: 0 10px 22px rgba(31,41,51,.06); }
    .card-head { display: grid; grid-template-columns: auto 1fr auto; gap: 10px; align-items: start; }
    .rank { background: #a7f3d0; color: #075f55; border-radius: 999px; padding: 5px 9px; font-weight: 800; font-size: 13px; white-space: nowrap; }
    h2 { margin: 0; font-size: 18px; line-height: 1.32; }
    .favorite { width: 34px; height: 34px; border-radius: 50%; padding: 0; background: #fff; color: #a35c00; }
    .favorite.active { background: #fff2d5; border-color: #d99a24; }
    .meta { color: var(--muted); font-size: 13px; line-height: 1.5; }
    .chips { display: flex; flex-wrap: wrap; gap: 6px; }
    .chip { background: #f0f4f8; border: 1px solid var(--line); border-radius: 999px; padding: 4px 8px; font-size: 12px; color: #334e68; }
    .zh-summary { font-size: 14px; line-height: 1.75; }
    .abstract { border-top: 1px dashed var(--line); padding-top: 10px; color: var(--muted); font-size: 13px; line-height: 1.65; }
    details summary { color: var(--accent); cursor: pointer; font-weight: 700; }
    .actions { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; margin-top: auto; }
    .actions a, .prompt { border: 1px solid var(--line); border-radius: 6px; padding: 9px 10px; text-decoration: none; color: var(--ink); background: #fbfdff; font-size: 13px; text-align: center; }
    .actions a.primary-link { background: var(--soft); border-color: #9de4d9; color: #075f55; font-weight: 800; }
    .prompt { grid-column: 1 / -1; text-align: left; color: var(--muted); word-break: break-word; }
    .hidden { display: none !important; }
    .empty { background: var(--panel); border: 1px solid var(--line); border-radius: 8px; padding: 28px; text-align: center; color: var(--muted); }
    .pagination { display: flex; align-items: center; justify-content: center; gap: 10px; margin-top: 28px; flex-wrap: wrap; }
    .pagination button { min-width: 38px; height: 38px; border-radius: 6px; padding: 0 12px; font-weight: 700; }
    .pagination button.active { background: var(--accent); border-color: #085f5a; color: #fff; }
    .pagination button:disabled { opacity: .35; cursor: default; }
    .pagination .page-info { color: var(--muted); font-size: 13px; white-space: nowrap; }
    .page-size-wrap { display: flex; align-items: center; gap: 6px; color: var(--muted); font-size: 13px; }
    .page-size-wrap select { padding: 6px 8px; font-size: 13px; }
    @media (max-width: 1100px) { .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } .filters { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @media (max-width: 720px) { main { padding: 16px; } .grid, .filters { grid-template-columns: 1fr; } header p { margin-left: 0; } }
  </style>
</head>
<body>
<header>
  <div class="title-row"><span class="dot"></span><h1>论文阅读工作台</h1></div>
  <p>收录 {{ paper_count }} 篇 · 已精读 {{ deep_read_count }} 篇 · 更新 {{ generated_at }}</p>
</header>
<main>
  <section class="toolbar">
    <div class="filters">
      <label>日期维度
        <select id="dateMode"><option value="captured">抓取日期</option></select>
      </label>
      <label>开始日期
        <input id="startDate" type="date">
      </label>
      <label>结束日期
        <input id="endDate" type="date">
      </label>
      <label>关键词
        <input id="keyword" type="search" placeholder="标题/作者/摘要/主题关键词">
      </label>
      <label>状态
        <select id="statusFilter">
          <option value="all">全部</option>
          <option value="deep">只看已精读</option>
          <option value="pending">只看待精读</option>
          <option value="favorite">只看收藏</option>
        </select>
      </label>
    </div>
    <div style="display:flex; gap:10px; margin-top:14px; justify-content:flex-end;">
      <button class="primary" id="applyBtn">筛选</button>
      <button id="resetBtn">重置</button>
    </div>
  </section>

  <div class="stats">
    <span id="resultCount">当前显示 {{ paper_count }} 篇</span>
    <span>自然语言示例：给我 2026-05-02 抓取的第 1 篇论文的精读</span>
  </div>

  <section class="grid" id="paperGrid">
    {% for paper in papers %}
    <article class="paper-card" data-date="{{ paper.captured_date }}" data-deep="{{ '1' if paper.has_deep_read else '0' }}" data-record="{{ paper.record_id }}" data-search="{{ paper.search_text }}">
      <div class="card-head">
        <span class="rank">{{ paper.captured_date }} #{{ paper.date_rank }}</span>
        <h2>{{ paper.title }}</h2>
        <button class="favorite" title="收藏" data-fav="{{ paper.record_id }}">☆</button>
      </div>
      <div class="meta">抓取：{{ paper.captured_at[:10] }} · 作者：{{ paper.authors_text }} · {{ paper.year or 'n.d.' }} · {{ paper.venue or '未知来源' }}</div>
      <div class="chips">
        <span class="chip">{{ paper.source or 'source?' }}</span>
        <span class="chip">{{ paper.paper_type or 'research paper' }}</span>
        <span class="chip">Score {{ paper.score }}</span>
        <span class="chip">{{ '已精读' if paper.has_deep_read else '待精读' }}</span>
      </div>
      <div class="zh-summary"><strong>中文总结</strong><br>{{ paper.zh_takeaway or '暂无中文总结。' }}</div>
      <details class="abstract"><summary>查看 Abstract / 来源信息</summary>{{ paper.abstract or '当前数据源未提供摘要。' }}</details>
      <div class="actions">
        {% if paper.report_href %}<a class="primary-link" href="{{ paper.report_href }}">打开深读报告</a>{% endif %}
        {% if paper.reading_href %}<a href="{{ paper.reading_href }}">打开分块译读</a>{% endif %}
        {% if paper.url %}<a href="{{ paper.url }}">论文来源</a>{% endif %}
        {% if paper.screening_json_href %}<a href="{{ paper.screening_json_href }}">记录 JSON</a>{% endif %}
        <div class="prompt">自然语言：{{ paper.date_prompt }}</div>
      </div>
    </article>
    {% endfor %}
  </section>
  <section class="empty hidden" id="emptyState">没有匹配的论文记录。</section>

  <div class="pagination" id="pagination"></div>
  <div class="page-size-wrap" style="justify-content:center; margin-top:12px;">
    每页显示
    <select id="pageSize">
      <option value="12" selected>12 篇</option>
      <option value="24">24 篇</option>
      <option value="48">48 篇</option>
      <option value="0">全部</option>
    </select>
  </div>
</main>
<script>
  const favoritesKey = 'thesis-reading-library-favorites';
  const favoriteSet = new Set(JSON.parse(localStorage.getItem(favoritesKey) || '[]'));
  const cards = Array.from(document.querySelectorAll('.paper-card'));
  const resultCount = document.getElementById('resultCount');
  const emptyState = document.getElementById('emptyState');
  const paginationEl = document.getElementById('pagination');
  const pageSizeEl = document.getElementById('pageSize');

  let filteredCards = [];
  let currentPage = 1;

  function saveFavorites() {
    localStorage.setItem(favoritesKey, JSON.stringify(Array.from(favoriteSet)));
  }

  function syncFavorites() {
    document.querySelectorAll('[data-fav]').forEach(button => {
      const id = button.dataset.fav;
      button.classList.toggle('active', favoriteSet.has(id));
      button.textContent = favoriteSet.has(id) ? '★' : '☆';
    });
  }

  function getPageSize() {
    return parseInt(pageSizeEl.value, 10);
  }

  function renderPage() {
    const pageSize = getPageSize();
    const total = filteredCards.length;
    const totalPages = pageSize === 0 ? 1 : Math.max(1, Math.ceil(total / pageSize));
    currentPage = Math.min(currentPage, totalPages);

    cards.forEach(c => c.classList.add('hidden'));
    if (pageSize === 0) {
      filteredCards.forEach(c => c.classList.remove('hidden'));
    } else {
      const start = (currentPage - 1) * pageSize;
      filteredCards.slice(start, start + pageSize).forEach(c => c.classList.remove('hidden'));
    }

    resultCount.textContent = `当前显示 ${total} 篇（第 ${currentPage} / ${totalPages} 页）`;
    emptyState.classList.toggle('hidden', total !== 0);
    renderPagination(totalPages);
  }

  function renderPagination(totalPages) {
    paginationEl.innerHTML = '';
    if (totalPages <= 1) return;

    const prev = document.createElement('button');
    prev.textContent = '‹ 上一页';
    prev.disabled = currentPage === 1;
    prev.addEventListener('click', () => { currentPage--; renderPage(); window.scrollTo(0, 0); });
    paginationEl.appendChild(prev);

    // show at most 7 page buttons with ellipsis
    const range = buildPageRange(currentPage, totalPages);
    range.forEach(p => {
      if (p === '…') {
        const span = document.createElement('span');
        span.className = 'page-info';
        span.textContent = '…';
        paginationEl.appendChild(span);
      } else {
        const btn = document.createElement('button');
        btn.textContent = p;
        if (p === currentPage) btn.classList.add('active');
        btn.addEventListener('click', () => { currentPage = p; renderPage(); window.scrollTo(0, 0); });
        paginationEl.appendChild(btn);
      }
    });

    const next = document.createElement('button');
    next.textContent = '下一页 ›';
    next.disabled = currentPage === totalPages;
    next.addEventListener('click', () => { currentPage++; renderPage(); window.scrollTo(0, 0); });
    paginationEl.appendChild(next);

    const info = document.createElement('span');
    info.className = 'page-info';
    info.textContent = `共 ${filteredCards.length} 篇`;
    paginationEl.appendChild(info);
  }

  function buildPageRange(cur, total) {
    if (total <= 7) return Array.from({length: total}, (_, i) => i + 1);
    const pages = [];
    pages.push(1);
    if (cur > 3) pages.push('…');
    for (let p = Math.max(2, cur - 1); p <= Math.min(total - 1, cur + 1); p++) pages.push(p);
    if (cur < total - 2) pages.push('…');
    pages.push(total);
    return pages;
  }

  function applyFilters() {
    const start = document.getElementById('startDate').value;
    const end = document.getElementById('endDate').value;
    const keyword = document.getElementById('keyword').value.trim().toLowerCase();
    const status = document.getElementById('statusFilter').value;
    filteredCards = cards.filter(card => {
      const date = card.dataset.date;
      const deep = card.dataset.deep === '1';
      const record = card.dataset.record;
      const matchesDate = (!start || date >= start) && (!end || date <= end);
      const matchesKeyword = !keyword || card.dataset.search.includes(keyword);
      const matchesStatus = status === 'all' || (status === 'deep' && deep) || (status === 'pending' && !deep) || (status === 'favorite' && favoriteSet.has(record));
      return matchesDate && matchesKeyword && matchesStatus;
    });
    currentPage = 1;
    renderPage();
  }

  document.getElementById('applyBtn').addEventListener('click', applyFilters);
  document.getElementById('resetBtn').addEventListener('click', () => {
    document.getElementById('startDate').value = '';
    document.getElementById('endDate').value = '';
    document.getElementById('keyword').value = '';
    document.getElementById('statusFilter').value = 'all';
    applyFilters();
  });
  document.getElementById('keyword').addEventListener('input', applyFilters);
  document.getElementById('statusFilter').addEventListener('change', applyFilters);
  pageSizeEl.addEventListener('change', () => { currentPage = 1; renderPage(); });
  document.querySelectorAll('[data-fav]').forEach(button => {
    button.addEventListener('click', () => {
      const id = button.dataset.fav;
      if (favoriteSet.has(id)) favoriteSet.delete(id); else favoriteSet.add(id);
      saveFavorites();
      syncFavorites();
      applyFilters();
    });
  });
  syncFavorites();
  applyFilters();
</script>
</body>
</html>
