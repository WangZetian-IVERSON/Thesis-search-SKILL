<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <title>{{ title }}</title>
  <style>
    :root {
      --ink: #1f2933;
      --muted: #52606d;
      --line: #d9e2ec;
      --panel: #ffffff;
      --bg: #f7f7f4;
      --nav: #243b53;
      --accent: #0b69a3;
    }
    body { margin: 0; font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: var(--bg); color: var(--ink); }
    header { background: var(--nav); color: #fff; padding: 28px 36px; }
    header h1 { margin: 0 0 8px; font-size: 28px; }
    header p { margin: 0; color: #d9e2ec; }
    main { max-width: 1180px; margin: 0 auto; padding: 28px; }
    section { margin-bottom: 28px; }
    h2 { border-bottom: 1px solid var(--line); padding-bottom: 8px; }
    table { border-collapse: collapse; width: 100%; background: var(--panel); }
    th, td { border: 1px solid var(--line); padding: 8px 10px; text-align: left; vertical-align: top; }
    th { background: #edf2f7; }
    .paper { background: var(--panel); border: 1px solid var(--line); border-radius: 6px; padding: 18px; margin-bottom: 18px; }
    .meta { color: var(--muted); }
    .two-col { display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 0.8fr); gap: 18px; }
    .quote { border-left: 4px solid var(--accent); padding-left: 12px; color: #334e68; white-space: pre-wrap; }
    .card { background: #fbfdff; border: 1px solid var(--line); border-radius: 4px; padding: 12px; margin-bottom: 12px; }
    .analysis-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 14px; }
    .analysis-card { background: var(--panel); border: 1px solid var(--line); border-radius: 6px; padding: 14px; }
    .analysis-card h4 { margin: 0 0 8px; }
    .summary-box { background: #f8fafc; border: 1px solid var(--line); border-radius: 4px; padding: 10px; }
    .summary-box h5 { margin: 0 0 6px; font-size: 13px; color: var(--muted); }
    .summary-box p { margin: 0; }
    .deep-points { margin: 10px 0 0; padding-left: 20px; color: #334e68; line-height: 1.65; }
    .deep-points li { margin: 6px 0; }
    details.evidence-details { margin-top: 10px; color: var(--muted); }
    details.evidence-details summary { cursor: pointer; color: var(--accent); font-weight: 700; }
    .evidence-list { color: var(--muted); font-size: 13px; padding-left: 18px; }
    .figure-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
    figure { margin: 0; background: var(--panel); border: 1px solid var(--line); border-radius: 6px; padding: 10px; }
    figure img { width: 100%; height: auto; border: 1px solid var(--line); }
    figcaption { color: var(--muted); font-size: 13px; margin-top: 8px; }
    a { color: var(--accent); }
    @media (max-width: 800px) { .two-col { grid-template-columns: 1fr; } main { padding: 16px; } }
  </style>
</head>
<body>
<header>
  <h1>{{ title }}</h1>
  <p>Generated by thesis-reading-skill · {{ generated_at }}</p>
</header>
<main>
  <section>
    <h2>文献总览</h2>
    {% if papers %}
    <table>
      <thead><tr><th>标题</th><th>作者</th><th>年份</th><th>来源</th><th>状态</th><th>链接</th></tr></thead>
      <tbody>
      {% for paper in papers %}
        <tr>
          <td>{{ paper.title }}</td>
          <td>{{ paper.authors | join(', ') }}</td>
          <td>{{ paper.year or '' }}</td>
          <td>{{ paper.venue or '' }}</td>
          <td>{{ paper.fulltext_status }}</td>
          <td>{% if paper.url %}<a href="{{ paper.url }}">link</a>{% endif %}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p>暂无检索元数据。</p>
    {% endif %}
  </section>

  <section>
    <h2>逐篇精读</h2>
    {% if readings %}
      <table>
        <thead><tr><th>论文</th><th>模式</th><th>阅读问题</th><th>注释数</th><th>分块译读页</th></tr></thead>
        <tbody>
        {% for reading in readings %}
          <tr>
            <td>{{ reading.title }}</td>
            <td>{{ reading.mode }}</td>
            <td>{{ reading.questions | join('; ') }}</td>
            <td>{{ reading.annotation_count }}</td>
            <td><a href="{{ reading.output_html }}">打开</a></td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    {% endif %}
    {% if analyses %}
      {% for analysis in analyses %}
      <article class="paper">
        <h3>{{ analysis.title }}</h3>
        <p class="meta">{{ analysis.analysis_status }} · {{ analysis.topic or 'no topic provided' }}</p>
        <div class="analysis-grid">
          {% for key in ['research_problem', 'core_claim', 'method', 'evidence', 'limitations'] %}
            {% set section = analysis.sections[key] %}
            <div class="analysis-card">
              <h4>{{ section.label_zh or section.label }}</h4>
              <section class="summary-box">
                <h5>详细解读</h5>
                <p>{{ section.deep_summary_zh or section.summary_zh or section.summary }}{% if section.page %} <span class="meta">page {{ section.page }}</span>{% endif %}</p>
                {% if section.deep_points_zh %}
                <ul class="deep-points">
                  {% for point in section.deep_points_zh %}
                  <li>{{ point }}</li>
                  {% endfor %}
                </ul>
                {% endif %}
              </section>
              {% if section.evidence %}
              <details class="evidence-details">
                <summary>查看原文证据</summary>
                <ul class="evidence-list">
                  {% for item in section.evidence[:2] %}
                  <li>page {{ item.page }}: {{ item.quote }}</li>
                  {% endfor %}
                </ul>
              </details>
              {% endif %}
            </div>
          {% endfor %}
        </div>
        <div class="card">
          <strong>{{ analysis.relevance.label_zh or analysis.relevance.label }}</strong>
          <section class="summary-box">
            <h5>详细解读</h5>
            <p>{{ analysis.relevance.summary_zh or analysis.relevance.summary }}</p>
            {% if analysis.relevance.deep_points_zh %}
            <ul class="deep-points">
              {% for point in analysis.relevance.deep_points_zh %}
              <li>{{ point }}</li>
              {% endfor %}
            </ul>
            {% endif %}
          </section>
        </div>
      </article>
      {% endfor %}
    {% endif %}
    {% if parsed_papers and not analyses %}
      {% for parsed in parsed_papers %}
      <article class="paper">
        <h3>{{ parsed.title }}</h3>
        <p class="meta">{{ parsed.source_pdf }} · {{ parsed.page_count }} pages</p>
        <div class="two-col">
          <div>
            <h4>原文摘录</h4>
            <p class="quote">{{ parsed.excerpt }}</p>
          </div>
          <div>
            <div class="card"><strong>研究问题</strong><br>待 Agent 根据全文补充。</div>
            <div class="card"><strong>核心论点</strong><br>待 Agent 根据全文补充，并绑定页码证据。</div>
            <div class="card"><strong>方法与证据</strong><br>待 Agent 区分作者证据和推断。</div>
            <div class="card"><strong>局限</strong><br>待 Agent 标注作者自述局限和潜在局限。</div>
          </div>
        </div>
      </article>
      {% endfor %}
    {% elif not analyses and not readings %}
      <p>暂无 PDF 解析结果。运行 <code>scripts/parse_pdf.py</code> 后可生成逐篇精读区块。</p>
    {% endif %}
  </section>

  <section>
    <h2>图表证据库</h2>
    {% if figures %}
    <div class="figure-grid">
      {% for item in figures %}
      <figure>
        <img src="{{ item.screenshot }}" alt="{{ item.figure_id }}">
        <figcaption>{{ item.paper_id }} · {{ item.figure_id }} · page {{ item.page }} · {{ item.caption }}</figcaption>
      </figure>
      {% endfor %}
    </div>
    {% else %}
      <p>暂无图表截图 manifest。</p>
    {% endif %}
  </section>

  <section>
    <h2>审计提示</h2>
    <p>最终提交前运行 <code>scripts/audit_report.py</code>，检查论文来源、图表截图、报告文件和全文状态。</p>
  </section>
</main>
</body>
</html>
